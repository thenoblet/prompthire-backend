# Required: primary model id passed to litellm. App refuses to start if unset.
# Examples:
#   gemini/gemini-2.5-flash, anthropic/claude-haiku-4-5, gpt-4o-mini, openai/gpt-4o-mini,
#   groq/llama-3.1-70b-versatile, openrouter/<provider>/<model>:<tag>
LITELLM_MODEL=gemini/gemini-2.5-flash

# Optional. Comma-separated fallback model chain. Tried in order if the primary
# exhausts its retries. Each fallback gets its own 3-attempt tenacity budget.
# Picking fallbacks across DIFFERENT providers is recommended — if one
# provider is having an outage, the others are unaffected. The example below
# tries Gemini first; on retry exhaustion, falls back to two OpenRouter free
# models so the demo stays alive when Google free-tier rate-limits us.
# Worst-case wallclock per request grows linearly with the chain length
# (~30s per model, so 3 models ≈ 90s). Trim by reducing MAX_RETRY_ATTEMPTS
# in infrastructure/llm.py if too slow.
LITELLM_FALLBACK_MODELS=openrouter/poolside/laguna-m.1:free,openrouter/meta-llama/llama-3.1-8b-instruct:free

# Required: provider key matching whatever models are in LITELLM_MODEL or LITELLM_FALLBACK_MODELS.
# Set the one(s) you use; the rest can stay blank or be removed.
# load_dotenv() in main.py exports these to os.environ so litellm picks them up automatically.
GEMINI_API_KEY=
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=

# Required: Postgres connection string (must use the asyncpg driver).
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/prompthire

# Optional. Comma-separated allowed origins for CORS. Empty = same-origin only.
CORS_ORIGINS=

# Optional. Per-IP requests/minute on /api/v1/generate. Default 5.
RATE_LIMIT_PER_MIN=5

# Optional. Per-IP requests/day on /api/v1/generate. Default 20.
RATE_LIMIT_PER_DAY=20

# Optional. Global cap on LLM calls per UTC day across all IPs. Default 200.
# Cache hits do NOT count toward this. Tune below the smaller of your provider RPDs
# (e.g. 200 with a 50-call buffer below Gemini 2.5 Flash's 250 RPD).
GLOBAL_DAILY_CAP=200

# Optional. Toggle the question cache. Default true.
CACHE_ENABLED=true

# Optional. Cache entry lifetime in hours. Default 24.
CACHE_TTL_HOURS=24

# Optional. Hard ceiling on a single LLM call. Default 30.
LITELLM_TIMEOUT_SECONDS=30

# Optional. Log level. Default INFO.
LOG_LEVEL=INFO

# Optional. Trust the first hop of X-Forwarded-For (set true behind nginx). Default false.
TRUST_FORWARDED_FOR=false
